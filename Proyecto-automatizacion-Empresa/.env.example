# ============================================
# PROYECTO: Automatización Playwright
# ============================================
# Instrucciones:
# 1. Copia este archivo y renómbralo a .env
# 2. Completa los valores reales
# 3. NUNCA subas .env al repositorio
# ============================================

# ---------- OBLIGATORIAS ----------
# URL base de la aplicación (sin barra al final)
BASE_URL=

# Credenciales de administrador
USER_ADMIN=
PASS_ADMIN=

# ---------- OPCIONALES ----------
# Tiempo de espera en milisegundos (por defecto: 30000)
TIMEOUT=30000

# Entorno: desarrollo, staging, produccion (por defecto: desarrollo)
ENV=desarrollo

# ---------- EJEMPLO CON VALORES REALES ----------
# BASE_URL=https://opensource-demo.orangehrmlive.com
# USER_ADMIN=Admin
# PASS_ADMIN=admin123
# TIMEOUT=30000
# ENV=desarrollo