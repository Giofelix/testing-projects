def getEntidadesValidas() {
    return [
        'cajica', 'sogamoso', 'honda', 'melgar', 'florencia',
        'sanmartin', 'corpoboyaca', 'gobnarino', 'pasto', 'demo',
        'duitama', 'trinidad', 'alc_vleyva', 'alc_cubara', 'alc_buenavista'
    ]
}

/**
 * URL base por entidad. Patrón confirmado: http://172.17.1.214:9080/{entidad}/
 */
def buildEntityUrl(String entidad) {
    return "http://172.17.1.214:9080/${entidad}/"
}

/**
 * Resuelve qué credenciales usar para una entidad, con fallback seguro.
 * El chequeo de existencia está AISLADO (sh 'true' trivial) de la ejecución
 * real de tests, para que un fallo de prueba nunca se confunda con
 * "credencial no encontrada".
 */
def resolveCredentialIds(String entidad) {
    def entidadUpper = entidad.toUpperCase()
    def specificUser = "${entidadUpper}_USER"
    def specificPass = "${entidadUpper}_PASS"

    try {
        withCredentials([
            string(credentialsId: specificUser, variable: 'CHK_USER'),
            string(credentialsId: specificPass, variable: 'CHK_PASS')
        ]) {
            sh 'true'  // no-op, solo fuerza la resolución de la credencial
        }
        echo "  🔑 Usando credenciales específicas: ${specificUser}/${specificPass}"
        return [userCredId: specificUser, passCredId: specificPass, source: 'entidad']
    } catch (Exception e) {
        echo "  🔑 Sin credenciales específicas (${specificUser}). Usando USER_GENERIC/PASSWORD_UNIVERSAL"
        return [userCredId: 'USER_GENERIC', passCredId: 'PASSWORD_UNIVERSAL', source: 'generic']
    }
}

def validateDeploymentParams() {
    def map = getMicroservicioToTagMap()
    def validEntities = getEntidadesValidas()
    def errors = []

    def microservicios = params.PROJECT_NAME.split(',').collect { it.trim() }.findAll { it }
    def entidades      = params.ENTITIES.split(',').collect { it.trim().toLowerCase() }.findAll { it }

    def moduleTags = []
    microservicios.each { ms ->
        def tag = map[ms]
        if (!tag) {
            errors << "PROJECT_NAME desconocido: '${ms}'. Revisar getMicroservicioToTagMap()."
        } else {
            moduleTags << tag
        }
    }

    entidades.each { ent ->
        if (!validEntities.contains(ent)) {
            errors << "ENTITY desconocida: '${ent}'. Revisar getEntidadesValidas()."
        }
    }

    if (moduleTags.isEmpty()) errors << "No se resolvió ningún PROJECT_NAME válido"
    if (entidades.isEmpty())  errors << "No se especificó ninguna ENTITY"

    return [
        valid: errors.isEmpty(),
        errors: errors,
        moduleTags: moduleTags.unique(),
        entities: entidades.unique()
    ]
}

/**
 * Ejecuta tests para una entidad (o varias en modo combinado).
 */
def runDeploymentTestsForEntity(List moduleTags, List entidades, String testType, String label) {
    def moduleAlt = moduleTags.collect { "@${it}" }.join('|')
    def entidadAlt = entidades.collect { "@${it}" }.join('|') + '|@todas_entidades'

    def lookaheads = [
        "(?=.*(${moduleAlt}))",
        "(?=.*(${entidadAlt}))"
    ]

    if (testType == 'e2e')        lookaheads << '(?=.*@e2e)' 
    if (testType == 'smoke')      lookaheads << '(?=.*@smoke)'
    if (testType == 'regression') lookaheads << '(?=.*(@regression|@smoke|@critical))'
    if (testType == 'critical')   lookaheads << '(?=.*@critical)'

    def grepPattern = lookaheads.join('')

    def baseUrl = entidades.size() == 1 ? buildEntityUrl(entidades[0]) : env.BASE_URL
    def creds = entidades.size() == 1
        ? resolveCredentialIds(entidades[0])
        : [userCredId: 'USER_GENERIC', passCredId: 'PASSWORD_UNIVERSAL', source: 'generic-combined']

    echo "  🔎 Grep:      ${grepPattern}"
    echo "  🌐 BASE_URL:  ${baseUrl}"
    echo "  🔑 Creds:     ${creds.userCredId}/${creds.passCredId} (origen: ${creds.source})"

    def allureDir = "allure-results-${label}"

    withCredentials([
        string(credentialsId: creds.userCredId, variable: 'USER_GENERIC'),
        string(credentialsId: creds.passCredId, variable: 'PASSWORD_UNIVERSAL')
    ]) {
        sh """
            export BASE_URL='${baseUrl}'
            if [ -d ${allureDir} ]; then rm -rf ${allureDir}; fi
            mkdir -p ${allureDir}

            LANG=es_ES.UTF-8 LANGUAGE=es_ES:es LC_ALL=es_ES.UTF-8 \\
            ALLURE_RESULTS_DIR=${allureDir} \\
            npx playwright test --grep '${grepPattern}'

            cp -r ${allureDir}/* allure-results/ 2>/dev/null || true
        """
    }
}